{
  "openapi": "3.0.1",
  "info": {
    "title": "String Search API",
    "description": "API para comparação de algoritmos de busca de padrões em strings. Padrões arquiteturais: Strategy + Facade.",
    "version": "v1"
  },
  "paths": {
    "/api/Search/execute": {
      "post": {
        "tags": [
          "Search"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Search/step-by-step": {
      "post": {
        "tags": [
          "Search"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StepSearchCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StepSearchCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StepSearchCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StepSearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Search/multi-file": {
      "post": {
        "tags": [
          "Search"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MultiFileSearchCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/MultiFileSearchCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/MultiFileSearchCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MultiFileSearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Search/compare-all": {
      "post": {
        "tags": [
          "Search"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Search/algorithms": {
      "get": {
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlgorithmInfo"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AlgorithmInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "bestCase": {
            "type": "string",
            "nullable": true
          },
          "averageCase": {
            "type": "string",
            "nullable": true
          },
          "worstCase": {
            "type": "string",
            "nullable": true
          },
          "spaceComplexity": {
            "type": "string",
            "nullable": true
          },
          "useCaseDescription": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AuxiliaryStructure": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "data": {
            "type": "object",
            "additionalProperties": { },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FileContent": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "content": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FileSearchResult": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "result": {
            "$ref": "#/components/schemas/SearchResult"
          }
        },
        "additionalProperties": false
      },
      "MultiFileSearchCommand": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileContent"
            },
            "nullable": true
          },
          "pattern": {
            "type": "string",
            "nullable": true
          },
          "algorithm": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MultiFileSearchResult": {
        "type": "object",
        "properties": {
          "fileResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileSearchResult"
            },
            "nullable": true
          },
          "algorithm": {
            "type": "string",
            "nullable": true
          },
          "totalExecutionTimeMs": {
            "type": "integer",
            "format": "int64"
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "SearchCommand": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "nullable": true
          },
          "pattern": {
            "type": "string",
            "nullable": true
          },
          "algorithm": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string",
            "nullable": true
          },
          "algorithmDisplayName": {
            "type": "string",
            "nullable": true
          },
          "occurrences": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          },
          "totalOccurrences": {
            "type": "integer",
            "format": "int32"
          },
          "executionTimeMs": {
            "type": "integer",
            "format": "int64"
          },
          "executionTimeNs": {
            "type": "integer",
            "format": "int64"
          },
          "totalComparisons": {
            "type": "integer",
            "format": "int32"
          },
          "textLength": {
            "type": "integer",
            "format": "int32"
          },
          "patternLength": {
            "type": "integer",
            "format": "int32"
          },
          "theoreticalComplexity": {
            "type": "string",
            "nullable": true
          },
          "complexityDescription": {
            "type": "string",
            "nullable": true
          },
          "complexityAnalysis": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SearchStep": {
        "type": "object",
        "properties": {
          "stepNumber": {
            "type": "integer",
            "format": "int32"
          },
          "textIndex": {
            "type": "integer",
            "format": "int32"
          },
          "patternIndex": {
            "type": "integer",
            "format": "int32"
          },
          "textChar": {
            "type": "string"
          },
          "patternChar": {
            "type": "string"
          },
          "isMatch": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "patternOffset": {
            "type": "integer",
            "format": "int32"
          },
          "comparedIndices": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StepSearchCommand": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "nullable": true
          },
          "pattern": {
            "type": "string",
            "nullable": true
          },
          "algorithm": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StepSearchResult": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string",
            "nullable": true
          },
          "algorithmDisplayName": {
            "type": "string",
            "nullable": true
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchStep"
            },
            "nullable": true
          },
          "occurrences": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          },
          "totalOccurrences": {
            "type": "integer",
            "format": "int32"
          },
          "totalComparisons": {
            "type": "integer",
            "format": "int32"
          },
          "auxiliaryStructure": {
            "$ref": "#/components/schemas/AuxiliaryStructure"
          }
        },
        "additionalProperties": false
      }
    }
  }
}