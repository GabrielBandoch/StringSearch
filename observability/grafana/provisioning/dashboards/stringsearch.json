{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "StringSearch API — Observabilidade com OpenTelemetry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Visão Geral",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total de Buscas",
      "description": "Número total de execuções desde o início",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(stringsearch_executions_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Taxa de Buscas (última hora)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(stringsearch_executions_total[1h])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Tempo Médio (p50)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1000000 },
              { "color": "red",    "value": 10000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.5, rate(stringsearch_execution_duration_ns_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Tempo p99",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5000000 },
              { "color": "red",    "value": 50000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(stringsearch_execution_duration_ns_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Tamanho do Último Texto",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "displayName": "chars" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "stringsearch_text_last_length",
          "legendFormat": "chars",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "row",
      "title": "Execuções por Algoritmo",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Execuções por Algoritmo (série temporal)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(stringsearch_executions_total[1m])",
          "legendFormat": "{{algorithm_display}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "barchart",
      "title": "Total de Execuções por Algoritmo",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (algorithm_display) (stringsearch_executions_total)",
          "legendFormat": "{{algorithm_display}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "Performance — Tempo de Execução",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Tempo Médio por Algoritmo (ns)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right",
          "calcs": ["mean", "min", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(stringsearch_execution_duration_ns_sum[1m]) / rate(stringsearch_execution_duration_ns_count[1m])",
          "legendFormat": "{{algorithm_display}} — média",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "type": "heatmap",
      "title": "Heatmap de Latência (ns)",
      "description": "Distribuição de tempo de execução por bucket",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "ns" },
        "color": { "scheme": "Oranges", "mode": "scheme" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(stringsearch_execution_duration_ns_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },

    {
      "id": 13,
      "type": "row",
      "title": "Comparações por Algoritmo",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Comparações Médias por Execução",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right",
          "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(stringsearch_comparisons_total_sum[1m]) / rate(stringsearch_comparisons_total_count[1m])",
          "legendFormat": "{{algorithm_display}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 15,
      "type": "bargauge",
      "title": "Total de Comparações Acumuladas",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-BlPu" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (algorithm_display) (stringsearch_comparisons_total_sum)",
          "legendFormat": "{{algorithm_display}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 16,
      "type": "row",
      "title": "Ocorrências Encontradas",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },

    {
      "id": 17,
      "type": "timeseries",
      "title": "Ocorrências Encontradas por Algoritmo",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(stringsearch_occurrences_total[1m])",
          "legendFormat": "{{algorithm_display}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 18,
      "type": "row",
      "title": "Runtime .NET",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": true,
      "panels": [
        {
          "id": 19,
          "type": "timeseries",
          "title": "GC Collections",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
          "fieldConfig": { "defaults": { "unit": "short" } },
          "targets": [
            {
              "datasource": "Prometheus",
              "expr": "rate(process_runtime_dotnet_gc_collections_count[1m])",
              "legendFormat": "Gen {{generation}}",
              "refId": "A"
            }
          ]
        },
        {
          "id": 20,
          "type": "timeseries",
          "title": "Heap Alocado (bytes)",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
          "fieldConfig": { "defaults": { "unit": "bytes" } },
          "targets": [
            {
              "datasource": "Prometheus",
              "expr": "process_runtime_dotnet_gc_heap_size_bytes",
              "legendFormat": "Gen {{generation}}",
              "refId": "A"
            }
          ]
        }
      ]
    }

  ],

  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["stringsearch", "opentelemetry", "dotnet"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "StringSearch — Observabilidade",
  "uid": "stringsearch-otel-v2",
  "version": 1
}
